# Required for deployed speaking transcription.
DEEPGRAM_API_KEY=

# Optional fallback transcription engine.
GROQ_API_KEY=

# Recommended for single-user Vercel deployment with shared mobile/desktop history.
# Stores evaluation summaries only. Audio recordings are not archived.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ATTEMPTS_TABLE=ielts_attempts

# Local/self-hosted fallback only. Vercel should use Supabase instead.
IELTS_COACH_ATTEMPTS_DIR=data/attempts
